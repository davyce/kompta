# ═══════════════════════════════════════════════════════
# KOMPTA — .gitignore
# ═══════════════════════════════════════════════════════

# ── Secrets & credentials ───────────────────────────────
.env
.env.local
.env.*.local
backend/.env
frontend/.env
# Contient les mots de passe de démo — NE PAS COMMITTER
IDENTIFIANTS.md

# ── Bases de données locales ────────────────────────────
*.db
*.sqlite
*.sqlite3
kompta.db
backend/kompta.db

# ── Python ──────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.so
.venv/
venv/
env/
ENV/
*.egg-info/
dist/
build/
.eggs/
*.egg
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover
nosetests.xml
pip-log.txt
pip-delete-this-directory.txt

# ── Node / Frontend ─────────────────────────────────────
node_modules/
frontend/node_modules/
dist/
frontend/dist/
.npm
*.tsbuildinfo
tsconfig.tsbuildinfo
tsconfig.node.tsbuildinfo
vite.config.js
vite.config.d.ts

# ── OS ──────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── IDE ─────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
.project
.classpath

# ── Logs ────────────────────────────────────────────────
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Uploads & storage local ─────────────────────────────
storage/uploads/
storage/*.tmp
backend/storage/uploads/

# ── Misc ────────────────────────────────────────────────
*.bak
*.orig
*.tmp
.cache/
.parcel-cache/
storage uploads
storage/documents/*
!storage/documents/.gitkeep
backend/storage/documents/*
!backend/storage/documents/.gitkeep

backend/storage/products/*
!backend/storage/products/.gitkeep
