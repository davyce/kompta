# ═══════════════════════════════════════════════════════
# KOMPTA — .gitignore
# ═══════════════════════════════════════════════════════

# ── Secrets & credentials ───────────────────────────────
.env
.env.local
.env.*.local
backend/.env
frontend/.env
# Contient les mots de passe de démo — NE PAS COMMITTER
IDENTIFIANTS.md

# ── Bases de données locales ────────────────────────────
*.db
*.sqlite
*.sqlite3
kompta.db
backend/kompta.db
# Backups de base (contiennent de VRAIES données — JAMAIS committer)
*.db.bak*
*.db.backup*
*.db-backup*
/backups/
backend/backups/

# ── Env de production backend (contient des secrets réels) ──
backend/.env.production
.env.production
# Exception : le .env.production du frontend ne contient AUCUN secret (juste VITE_API_URL=/api)
!frontend/.env.production

# ── Storage produits/uploads (données utilisateur locales) ──
storage/products/
backend/storage/products/

# ── Python ──────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.so
.venv/
venv/
env/
ENV/
*.egg-info/
dist/
build/
.eggs/
*.egg
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover
nosetests.xml
pip-log.txt
pip-delete-this-directory.txt

# ── Playwright (artefacts E2E) ──────────────────────────
test-results/
playwright-report/
playwright/.cache/
frontend/test-results/
frontend/playwright-report/

# ── Node / Frontend ─────────────────────────────────────
node_modules/
frontend/node_modules/
dist/
frontend/dist/
.npm
*.tsbuildinfo
tsconfig.tsbuildinfo
tsconfig.node.tsbuildinfo
vite.config.js
vite.config.d.ts

# ── OS ──────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── IDE ─────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
.project
.classpath

# ── Logs ────────────────────────────────────────────────
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Uploads & storage local ─────────────────────────────
storage/uploads/
storage/*.tmp
backend/storage/uploads/

# ── Misc ────────────────────────────────────────────────
*.bak
*.orig
*.tmp
.cache/
.parcel-cache/
storage uploads
storage/documents/*
!storage/documents/.gitkeep
backend/storage/documents/*
!backend/storage/documents/.gitkeep

backend/storage/products/*
!backend/storage/products/.gitkeep
infra/.tunnel-token

# ── Tauri desktop app (Windows/Linux) ───────────────────
kompta-desktop/src-tauri/target/
kompta-desktop/node_modules/

# ── Rapports internes / audits (usage interne uniquement, jamais publiés) ──
/AI_AUDIT.md
/API_MATRIX.md
/AUDIT_*.md
/DATABASE_AUDIT.md
/FINAL_MASTER_REPORT.md
/IOS_AUDIT.md
/MACOS_AUDIT.md
/PARITY_MATRIX.md
/PAYMENT_AUDIT.md
/PERFORMANCE_REPORT.md
/PRODUCTION_READINESS.md
/RAPPORT_*.md
/STATUT_APPS_NATIVES.md
/WEB_AUDIT.md
/audit_artifacts/
