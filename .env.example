# ── KOMPTA — Fichier d'exemple des variables d'environnement ─────────────────
# Copier en .env et personnaliser. Ne JAMAIS commiter .env avec de vrais secrets.

# ── Application ───────────────────────────────────────────────────────────────
ENVIRONMENT=development
# En production : changer pour une clé aléatoire longue (32+ chars)
# Générer avec : openssl rand -hex 32
SECRET_KEY=CHANGEME_generate_with_openssl_rand_hex_32

# ── Seed de démonstration ─────────────────────────────────────────────────────
# dev/local : true (crée admin@kompta.local / kompta123 et des données de test)
# PRODUCTION : false (base vide propre, aucune donnée exemple)
SEED_DEMO=true

# ── Base de données ───────────────────────────────────────────────────────────
# SQLite local : sqlite:///./kompta.db
# PostgreSQL prod : postgresql://user:password@host:5432/kompta
DATABASE_URL=sqlite:///./kompta.db

# ── CORS (origines autorisées) ────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3001,http://127.0.0.1:3001

# ── IA Limule (choisir un provider) ──────────────────────────────────────────
AI_PROVIDER=deepseek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
OPENAI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# ── Email SMTP (optionnel) ────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@kompta.app
SMTP_FROM_NAME=KOMPTA
SMTP_TLS=true
