# ── Application ──────────────────────────────────────────────────────────────
ENVIRONMENT=production
SECRET_KEY=change-me-generate-with-openssl-rand-hex-32
SEED_DEMO=false

# ── Base de données ───────────────────────────────────────────────────────────
# SQLite (défaut, simple)
DATABASE_URL=sqlite:///./kompta.db
# PostgreSQL (recommandé production)
# DATABASE_URL=postgresql://kompta:PASSWORD@localhost:5432/kompta

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=https://votre-domaine.com

# ── IA Limule ─────────────────────────────────────────────────────────────────
AI_PROVIDER=deepseek
DEEPSEEK_API_KEY=sk-...
# AI_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# AI_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434

# ── Email SMTP ────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.mailjet.com
SMTP_PORT=587
SMTP_USER=votre-api-key-mailjet
SMTP_PASSWORD=votre-secret-mailjet
SMTP_FROM_EMAIL=noreply@votre-domaine.com
SMTP_FROM_NAME=KOMPTA
