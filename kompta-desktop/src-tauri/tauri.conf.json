{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "KOMPTA",
  "version": "1.0.0",
  "identifier": "com.adansonia.kompta.desktop",
  "build": {
    "beforeDevCommand":   "cd ../frontend && npm run dev",
    "devUrl":             "http://localhost:3001",
    "beforeBuildCommand": "cd ../frontend && npm run build -- --mode desktop",
    "frontendDist":       "../../frontend/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "trayIcon": {
      "iconPath": "icons/tray-icon.png",
      "iconAsTemplate": true,
      "menuOnLeftClick": false
    },
    "windows": [
      {
        "title":          "KOMPTA",
        "width":          1280,
        "height":         800,
        "minWidth":       900,
        "minHeight":      600,
        "center":         true,
        "resizable":      true,
        "decorations":    true,
        "shadow":         true,
        "titleBarStyle":  "Overlay"
      }
    ],
    "security": {
      "csp": "default-src 'self' https://kompta0.com; connect-src 'self' https://kompta0.com ws://localhost:* wss://kompta0.com; img-src 'self' data: https:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "Adansonia",
    "copyright": "© 2026 Adansonia",
    "category": "Business",
    "shortDescription": "Gestion complète de votre entreprise",
    "longDescription": "KOMPTA est la plateforme de gestion d'entreprise pilotée par l'IA Limule — comptabilité, ventes, stocks, RH, projets et plus pour les PME africaines.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    },
    "linux": {
      "deb": {
        "depends": ["webkit2gtk-4.1"]
      },
      "appimage": {
        "bundleMediaFramework": true
      }
    }
  }
}
