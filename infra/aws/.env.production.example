# KOMPTA — variables de production (à copier en .env.production sur l'instance).
# NE JAMAIS committer .env.production rempli. Générer les secrets avec :
#   openssl rand -hex 32
#
# La prod utilise le docker-compose.yml RACINE (SQLite, pas de Postgres).
# Déploiement : docker compose --env-file infra/aws/.env.production ...

# --- Domaine & URL publique (via tunnel Cloudflare) ---
PUBLIC_URL=https://kompta0.com
CORS_ORIGINS=https://kompta0.com

# --- Sécurité backend ---
SECRET_KEY=                      # openssl rand -hex 32
SUPER_ADMIN_EMAIL=superadmin@kompta0.com
SUPER_ADMIN_PASSWORD=            # mot de passe fort

# --- Base de données ---
# Laisser vide → SQLite par défaut dans le volume (/app/storage/kompta.db).
# DATABASE_URL=

# --- IA ---
AI_PROVIDER=deepseek
DEEPSEEK_API_KEY=

# --- Paiements carte (Stripe — abonnement KOMPTA + clientèle internationale) ---
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Mobile Money (MTN MoMo — facultatif) ---
MOMO_SUBSCRIPTION_KEY=
MOMO_API_USER=
MOMO_API_KEY=
MOMO_TARGET_ENVIRONMENT=sandbox
MOMO_CALLBACK_SECRET=            # openssl rand -hex 32

# --- Email (facultatif) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@kompta0.com
SMTP_FROM_NAME=KOMPTA
