# KOMPTA — variables de production (à copier en .env.production sur l'instance).
# NE JAMAIS committer .env.production rempli. Générer les secrets avec :
#   openssl rand -hex 32

# --- Domaine & HTTPS ---
DOMAIN=app.kompta.com
TLS_EMAIL=admin@kompta.com
PUBLIC_URL=https://app.kompta.com
CORS_ORIGINS=https://app.kompta.com

# --- Sécurité backend ---
SECRET_KEY=                      # openssl rand -hex 32
SUPER_ADMIN_EMAIL=admin@kompta.com
SUPER_ADMIN_PASSWORD=            # mot de passe fort, à changer après 1ère connexion

# --- Base de données (Postgres conteneurisé) ---
POSTGRES_USER=kompta
POSTGRES_PASSWORD=               # openssl rand -hex 24
POSTGRES_DB=kompta

# --- IA ---
AI_PROVIDER=deepseek
DEEPSEEK_API_KEY=

# --- Paiements (prod) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
MOMO_CALLBACK_SECRET=            # openssl rand -hex 32

# --- Email ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@kompta.com

# --- Observabilité (recommandé) ---
SENTRY_DSN=

# --- Backups S3 (optionnel mais recommandé, voir backup.sh) ---
BACKUP_S3_BUCKET=
AWS_REGION=eu-west-3
