# KOMPTA — variables de production (à copier en .env.production sur l'instance).
# NE JAMAIS committer .env.production rempli. Générer les secrets avec :
#   openssl rand -hex 32
#
# La prod utilise le docker-compose.yml RACINE. SQLite par défaut ; un
# service Postgres optionnel (profil "postgres") est disponible pour la
# migration — voir scripts/migrate_sqlite_to_postgres.py et
# docs/POSTGRES_MIGRATION.md pour la procédure de bascule.
# Déploiement : docker compose --env-file infra/aws/.env.production ...

# --- Domaine & URL publique (via tunnel Cloudflare) ---
PUBLIC_URL=https://kompta0.com
CORS_ORIGINS=https://kompta0.com

# --- Sécurité backend ---
SECRET_KEY=                      # openssl rand -hex 32
SUPER_ADMIN_EMAIL=superadmin@kompta0.com
SUPER_ADMIN_PASSWORD=            # mot de passe fort

# --- Base de données ---
# Laisser vide → SQLite par défaut dans le volume (/app/storage/kompta.db).
# DATABASE_URL=

# --- PostgreSQL (optionnel — profil "postgres" du docker-compose racine) ---
# Ne rien remplir tant que la migration n'est pas faite. Une fois migré,
# décommenter DATABASE_URL ci-dessus avec :
#   DATABASE_URL=postgresql://kompta:${POSTGRES_PASSWORD}@postgres:5432/kompta
# POSTGRES_DB=kompta
# POSTGRES_USER=kompta
# POSTGRES_PASSWORD=            # openssl rand -hex 24

# --- IA ---
AI_PROVIDER=deepseek
DEEPSEEK_API_KEY=

# --- Paiements carte (Stripe — abonnement KOMPTA + clientèle internationale) ---
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Mobile Money (MTN MoMo — facultatif) ---
MOMO_SUBSCRIPTION_KEY=
MOMO_API_USER=
MOMO_API_KEY=
MOMO_TARGET_ENVIRONMENT=sandbox
MOMO_CALLBACK_SECRET=            # openssl rand -hex 32

# --- Email (facultatif) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@kompta0.com
SMTP_FROM_NAME=KOMPTA
