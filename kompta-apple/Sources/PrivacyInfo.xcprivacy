<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- KOMPTA ne fait aucun suivi publicitaire et n'utilise pas l'IDFA. -->
	<key>NSPrivacyTracking</key>
	<false/>
	<key>NSPrivacyTrackingDomains</key>
	<array/>
	<!-- Aucune donnée collectée à des fins de suivi par l'app elle-même.
	     Les données métier (compte, finances) sont stockées sur le serveur de
	     l'entreprise, liées à l'utilisateur, jamais utilisées pour du tracking. -->
	<key>NSPrivacyCollectedDataTypes</key>
	<array/>
	<!-- Required-reason APIs réellement utilisées. -->
	<key>NSPrivacyAccessedAPITypes</key>
	<array>
		<dict>
			<!-- UserDefaults : préférences locales (URL API, devise, options). -->
			<key>NSPrivacyAccessedAPIType</key>
			<string>NSPrivacyAccessedAPICategoryUserDefaults</string>
			<key>NSPrivacyAccessedAPITypeReasons</key>
			<array>
				<string>CA92.1</string>
			</array>
		</dict>
	</array>
</dict>
</plist>
