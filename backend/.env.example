APP_NAME=KOMPTA
ENVIRONMENT=local
# SECRET_KEY : génère avec python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-before-production
DATABASE_URL=sqlite:///./kompta.db
CORS_ORIGINS=http://localhost:3001,http://127.0.0.1:3001,http://localhost:5173,http://127.0.0.1:5173
ACCESS_TOKEN_EXPIRE_MINUTES=720

# ── Super-admin (OBLIGATOIRE en prod) ────────────────────────────────────
SUPER_ADMIN_EMAIL=superadmin@kompta.io
SUPER_ADMIN_PASSWORD=change-me-strong-password

# ── Authentification cookies ─────────────────────────────────────────────
# En production HTTPS : AUTH_COOKIE_SECURE=true
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax

# ── IA / Limule ──────────────────────────────────────────────────────────
AI_PROVIDER=deepseek
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ── Stripe (paiements carte) ─────────────────────────────────────────────
# Dashboard : https://dashboard.stripe.com/apikeys
# Webhook  : stripe listen --forward-to localhost:8010/api/payments/stripe/webhook
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxx
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=

# ── MTN Mobile Money ─────────────────────────────────────────────────────
# Provisioning : .venv/bin/python scripts/momo_provision.py
# Vérification : .venv/bin/python scripts/momo_provision.py --check
MOMO_SUBSCRIPTION_KEY=
MOMO_SUBSCRIPTION_KEY_SECONDARY=
MOMO_TARGET_ENVIRONMENT=sandbox
MOMO_BASE_URL=https://sandbox.momodeveloper.mtn.com
MOMO_API_USER=
MOMO_API_KEY=
# URL publique HTTPS pour callbacks MoMo (tunnel cloudflare en dev)
MOMO_CALLBACK_HOST=

# ── Email SMTP ───────────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@kompta.app
SMTP_FROM_NAME=KOMPTA
SMTP_TLS=true

# ── Intégrations diverses ────────────────────────────────────────────────
TERAS_API_URL=
TERAS_API_KEY=
ZOLA_API_KEY=
SMS_PROVIDER_API_KEY=
